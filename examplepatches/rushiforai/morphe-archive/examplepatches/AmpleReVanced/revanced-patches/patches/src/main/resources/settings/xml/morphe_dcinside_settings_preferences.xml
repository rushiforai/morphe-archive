<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">
    <PreferenceCategory android:title="@string/morphe_settings_section_features">
        <SwitchPreference
            android:key="morphe_pref_hide_official_notices"
            android:summary="@string/morphe_settings_hide_official_notices_summary"
            android:title="@string/morphe_settings_hide_official_notices" />
        <SwitchPreference
            android:key="morphe_pref_block_post_dccon_loading"
            android:summary="@string/morphe_settings_block_post_dccon_loading_summary"
            android:title="@string/morphe_settings_block_post_dccon_loading" />
        <SwitchPreference
            android:key="morphe_pref_block_reply_dccon_loading"
            android:summary="@string/morphe_settings_block_reply_dccon_loading_summary"
            android:title="@string/morphe_settings_block_reply_dccon_loading" />
        <SwitchPreference
            android:key="morphe_pref_render_big_dccon_as_normal"
            android:summary="@string/morphe_settings_render_big_dccon_as_normal_summary"
            android:title="@string/morphe_settings_render_big_dccon_as_normal" />
        <Preference
            android:key="morphe_pref_apply_user_memo_preset"
            android:summary="@string/morphe_settings_user_memo_preset_summary"
            android:title="@string/morphe_settings_user_memo_preset" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/morphe_settings_section_home_screen">
        <SwitchPreference
            android:key="morphe_pref_hide_home_search_menu"
            android:summary="@string/morphe_settings_hide_home_search_menu_summary"
            android:title="@string/morphe_settings_hide_home_search_menu" />
        <SwitchPreference
            android:key="morphe_pref_hide_home_recent_galleries"
            android:summary="@string/morphe_settings_hide_home_recent_galleries_summary"
            android:title="@string/morphe_settings_hide_home_recent_galleries" />
        <SwitchPreference
            android:key="morphe_pref_hide_home_recommended_galleries"
            android:summary="@string/morphe_settings_hide_home_recommended_galleries_summary"
            android:title="@string/morphe_settings_hide_home_recommended_galleries" />
        <SwitchPreference
            android:key="morphe_pref_hide_home_gallery_ranking"
            android:summary="@string/morphe_settings_hide_home_gallery_ranking_summary"
            android:title="@string/morphe_settings_hide_home_gallery_ranking" />
        <SwitchPreference
            android:key="morphe_pref_hide_home_live_best"
            android:summary="@string/morphe_settings_hide_home_live_best_summary"
            android:title="@string/morphe_settings_hide_home_live_best" />
        <SwitchPreference
            android:key="morphe_pref_hide_home_recommended_posts"
            android:summary="@string/morphe_settings_hide_home_recommended_posts_summary"
            android:title="@string/morphe_settings_hide_home_recommended_posts" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/morphe_settings_section_information">
        <Preference
            android:key="morphe_pref_app_version"
            android:selectable="false"
            android:title="@string/morphe_settings_app_version" />
        <Preference
            android:key="morphe_pref_patches_version"
            android:selectable="false"
            android:title="@string/morphe_settings_patches_version" />
        <Preference
            android:key="morphe_pref_package_name"
            android:selectable="false"
            android:title="@string/morphe_settings_package_name" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/morphe_settings_section_debug">
        <SwitchPreference
            android:key="morphe_pref_debug"
            android:summary="@string/morphe_settings_debug_summary"
            android:title="@string/morphe_settings_debug" />
        <SwitchPreference
            android:key="morphe_pref_debug_stacktrace"
            android:summary="@string/morphe_settings_debug_stacktrace_summary"
            android:title="@string/morphe_settings_debug_stacktrace" />
        <SwitchPreference
            android:key="morphe_pref_debug_toast"
            android:summary="@string/morphe_settings_debug_toast_summary"
            android:title="@string/morphe_settings_debug_toast" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/morphe_settings_section_manage">
        <Preference
            android:key="morphe_pref_clear_user_memos"
            android:summary="@string/morphe_settings_user_memo_clear_summary"
            android:title="@string/morphe_settings_user_memo_clear" />
        <Preference
            android:key="morphe_pref_reset"
            android:summary="@string/morphe_settings_reset_all_summary"
            android:title="@string/morphe_settings_reset_all" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/morphe_settings_section_links">
        <Preference
            android:key="morphe_pref_github"
            android:summary="@string/morphe_settings_link_github_summary"
            android:title="@string/morphe_settings_link_github">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://github.com/AmpleReVanced/revanced-patches" />
        </Preference>
        <Preference
            android:key="morphe_pref_telegram"
            android:summary="@string/morphe_settings_link_telegram_summary"
            android:title="@string/morphe_settings_link_telegram">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://t.me/ample_revanced_bot" />
        </Preference>
    </PreferenceCategory>
</PreferenceScreen>
